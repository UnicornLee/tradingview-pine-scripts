//@version=5
indicator("MACD Derivatives with Custom Levels", overlay=false)

// 输入参数
fast_length = input.int(12, "Fast Length", minval=1)
slow_length = input.int(26, "Slow Length", minval=1)
signal_length = input.int(9, "Signal Length", minval=1)
derivative_length = input.int(3, "Derivative Lookback Period", minval=2, tooltip="用于计算导数的周期数")
bg_transparency = input.int(90, "Background Transparency", minval=0, maxval=100, tooltip="背景透明度，0为完全透明，100为不透明")

// 计算MACD（仅用于表格）
fast_ema = ta.ema(close, fast_length)
slow_ema = ta.ema(close, slow_length)
macd_line = fast_ema - slow_ema
signal_line = ta.ema(macd_line, signal_length)
histogram = macd_line - signal_line

// 计算一阶导数（MACD线斜率，差分法）
var float slope = 0.0
if bar_index >= derivative_length
    slope := (macd_line - macd_line[derivative_length]) / derivative_length

// 计算二阶导数（斜率的斜率，差分法）
var float slope_of_slope = 0.0
if bar_index >= derivative_length * 2
    slope_prev = (macd_line[derivative_length] - macd_line[derivative_length * 2]) / derivative_length
    slope_of_slope := (slope - slope_prev) / derivative_length

// 计算三阶导数（二阶导数的变化率，差分法）
var float slope_of_slope_of_slope = 0.0
if bar_index >= derivative_length * 3
    slope_of_slope_prev = (slope[derivative_length] - slope[derivative_length * 2]) / derivative_length
    slope_of_slope_of_slope := (slope_of_slope - slope_of_slope_prev) / derivative_length

// 设置背景颜色（基于一阶导数和二阶导数）
bg_color = slope > 0 and slope_of_slope > 0 ? color.new(color.green, bg_transparency) :
           slope < 0 and slope_of_slope < 0 ? color.new(color.red, bg_transparency) :
           na
bgcolor(bg_color)

// 绘制水平虚线（MACD面板）
hline(1.5, "Level 1.5", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(1.0, "Level 1.0", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(0.5, "Level 0.5", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(-0.5, "Level -0.5", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(-1.0, "Level -1.0", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(-1.5, "Level -1.5", color=color.new(color.gray, 50), linestyle=hline.style_dashed)

// 绘制一阶导数（新面板）
p1 = plot(slope, "MACD Derivative", color=color.purple, linewidth=1, display=display.pane)
hline(0, "Derivative Zero", color=color.gray, linestyle=hline.style_dashed)

// 绘制二阶导数（新面板）
p2 = plot(slope_of_slope, "2nd Derivative", color=color.teal, linewidth=1, display=display.pane)
hline(0, "2nd Derivative Zero", color=color.gray, linestyle=hline.style_dashed)

// 绘制三阶导数（新面板）
p3 = plot(slope_of_slope_of_slope, "3rd Derivative", color=color.orange, linewidth=1, display=display.pane)
hline(0, "3rd Derivative Zero", color=color.gray, linestyle=hline.style_dashed)

// 表格显示最新值
var table t = table.new(position.top_right, 3, 6, border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "MACD", bgcolor=color.blue, text_color=color.white)
    table.cell(t, 1, 0, str.tostring(macd_line, "#.##"), bgcolor=color.blue, text_color=color.white)
    table.cell(t, 0, 1, "Signal", bgcolor=color.orange, text_color=color.white)
    table.cell(t, 1, 1, str.tostring(signal_line, "#.##"), bgcolor=color.orange, text_color=color.white)
    table.cell(t, 0, 2, "Histogram", bgcolor=histogram > 0 ? color.green : color.red, text_color=color.white)
    table.cell(t, 1, 2, str.tostring(histogram, "#.##"), bgcolor=histogram > 0 ? color.green : color.red, text_color=color.white)
    table.cell(t, 0, 3, "Derivative", bgcolor=color.purple, text_color=color.white)
    table.cell(t, 1, 3, str.tostring(slope, "#.##"), bgcolor=color.purple, text_color=color.white)
    table.cell(t, 0, 4, "2nd Derivative", bgcolor=color.teal, text_color=color.white)
    table.cell(t, 1, 4, str.tostring(slope_of_slope, "#.##"), bgcolor=color.teal, text_color=color.white)
    table.cell(t, 0, 5, "3rd Derivative", bgcolor=color.fuchsia, text_color=color.white)
    table.cell(t, 1, 5, str.tostring(slope_of_slope_of_slope, "#.##"), bgcolor=color.fuchsia, text_color=color.white)